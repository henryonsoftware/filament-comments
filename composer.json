{
    "name": "henryonsoftware/filament-comments",
    "description": "Add comments to your Filament Resources.",
    "keywords": [
        "filamentphp",
        "laravel",
        "filament-comments"
    ],
    "homepage": "https://github.com/henryonsoftware/filament-comments",
    "support": {
        "issues": "https://github.com/henryonsoftware/filament-comments/issues",
        "source": "https://github.com/henryonsoftware/filament-comments"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Henry Bui",
            "email": "viethuongdev@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "filament/filament": "^4.0",
        "spatie/laravel-package-tools": "^1.15.0",
        "illuminate/contracts": "^10.0 | ^11.0 | ^12.0"
    },
    "autoload": {
        "psr-4": {
            "HenryOnSoftware\\FilamentComments\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HenryOnSoftware\\FilamentComments\\FilamentCommentsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
